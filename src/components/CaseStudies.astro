---
import { MoveRight } from 'lucide-astro';

const cases = [
  {
    tag: 'Field Service Lightning · Experience Cloud',
    industry: 'Gaming & Entertainment',
    title: 'FSL implementation and portal for a global gaming technology company',
    problem: 'Field operations were managed manually — technicians had no mobile access to work orders, scheduling was ad hoc, and the client portal didn\'t exist. On top of that, the business needed Salesforce user identities synced to an external CIAM system in real time.',
    solution: 'Delivered a full Field Service Lightning rollout covering work orders, asset management, slot machine audit flows, and the dispatcher console. Built an Experience Cloud portal for client-facing access. Developed a custom CIAM integration using Queueable Apex and a Scheduler to sync Salesforce user records to the external identity system — with feature flags controlling the sync per environment.',
    result: 'Field technicians went fully mobile. Dispatchers had real-time job visibility. The CIAM sync ran reliably across dev, staging, and production without manual intervention.',
    metrics: ['FSL fully deployed', 'Real-time CIAM sync', 'Experience Cloud portal live'],
  },
  {
    tag: 'Integrations · Sales Cloud',
    industry: 'Logistics & Freight',
    title: 'Multi-system Salesforce integration connecting to Dynamics 365',
    problem: 'The business ran Salesforce alongside Microsoft Dynamics 365, with no reliable sync between them. Data was duplicated manually, errors were common, and there was no audit trail for integration failures.',
    solution: 'Architected a multi-project integration hub using Invocable Apex + Queueable callouts, with each integration behind a Custom Metadata feature flag for safe toggling per environment. Connected Salesforce to D365 via Azure Logic Apps, with full callout logging through a custom ApplicationLogEventManager. Set up a four-tier branching strategy (feature → project → DEV → main) with per-project sandboxes.',
    result: 'Integrations ran reliably across multiple Salesforce projects within the same org. Feature flags meant new callouts could be deployed and tested without affecting live data flows.',
    metrics: ['Zero manual data sync', 'Full callout audit trail', 'Multi-project sandbox pipeline'],
  },
  {
    tag: 'Service Cloud · Experience Cloud',
    industry: 'Legal & Professional Services',
    title: 'Client intake and case management platform for a traffic and road defence law firm',
    problem: 'The firm\'s intake process was scattered across emails, forms, and spreadsheets. Attorneys had no visibility into consultation history, court dates, or case status — and billing for admin fees was entirely manual.',
    solution: 'Built a comprehensive intake system using Screen Flows covering document upload, auto-pay, S-Docs generation, pricing and discount logic, and attorney consultation logging. Developed batch Apex classes to automate admin fee charge creation and opportunity record updates at scale. Added court date tracking automation and consultation recommendation flows for traffic and road-related cases.',
    result: 'New clients could be taken from first contact to intake in a single guided flow. The billing team stopped manually creating charges. Attorneys had full case history and upcoming court dates at a glance.',
    metrics: ['End-to-end intake automated', 'Batch billing eliminated manual work', 'Court date tracking centralised'],
  },
  {
    tag: 'Experience Cloud · Integrations',
    industry: 'Hospitality & Luxury',
    title: 'Guest management platform for a luxury hospitality group',
    problem: 'Guest data was fragmented across properties with no unified view, no centralised service layer, and no self-service portal for guests or internal staff.',
    solution: 'Designed and built a GuestManagementService Apex service layer following strict with-sharing patterns, centralising guest data operations across the org. Built LWC components for internal staff and delivered an Experience Cloud portal for guest-facing interactions.',
    result: 'Staff across properties had a single source of truth for guest records. The Experience Cloud portal reduced internal support load and gave the brand a digital touchpoint consistent with its luxury positioning.',
    metrics: ['Unified guest data model', 'LWC-powered staff interface', 'Experience Cloud portal live'],
  },
  {
    tag: 'Service Cloud · LWC',
    industry: 'Insurance & Financial Services',
    title: 'Insurance platform modernisation with multi-language support',
    problem: 'The existing insurance platform had no reusable component library, limited automation, and no support for multiple languages — making it difficult to serve a diverse customer base and scale across markets.',
    solution: 'Rebuilt key customer-facing and internal processes using Lightning Web Components and Aura components. Implemented Salesforce translations and multi-language support across the platform. Added message channels for cross-component communication and trigger-based automation for core insurance workflows.',
    result: 'The platform could now serve customers in multiple languages out of the box. The LWC component library reduced development time for new features significantly.',
    metrics: ['Multi-language platform', 'Reusable LWC library built', 'Trigger automation across workflows'],
  },
];
---

<section id="case-studies" class="section-padding border-t border-neutral-800/50">
  <div class="container-max">
    <div class="reveal mb-14">
      <p class="text-brand-500 font-semibold text-sm uppercase tracking-widest mb-3">Case Studies</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Problems solved</h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        Real projects, real outcomes. Details anonymized to protect client confidentiality.
      </p>
    </div>

    <div class="space-y-6">
      {cases.map((c) => (
        <div class="reveal bg-neutral-900 border border-neutral-800 rounded-2xl p-8 hover:border-neutral-700 transition-all duration-300">
          <div class="flex flex-col lg:flex-row lg:gap-12">
            <div class="lg:w-2/3">
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="inline-block bg-brand-900/50 border border-brand-500/30 text-brand-400 text-xs font-semibold px-3 py-1 rounded-full">
                  {c.tag}
                </span>
                <span class="inline-block bg-neutral-800 text-slate-400 text-xs font-semibold px-3 py-1 rounded-full">
                  {c.industry}
                </span>
              </div>
              <h3 class="text-2xl font-bold text-white mb-6">{c.title}</h3>

              <div class="space-y-4">
                <div>
                  <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-1">Problem</p>
                  <p class="text-slate-300">{c.problem}</p>
                </div>
                <div>
                  <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-1">What we did</p>
                  <p class="text-slate-300">{c.solution}</p>
                </div>
                <div>
                  <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-1">Result</p>
                  <p class="text-slate-300">{c.result}</p>
                </div>
              </div>
            </div>

            <div class="lg:w-1/3 mt-8 lg:mt-0 flex flex-col justify-center">
              <div class="bg-neutral-950 border border-neutral-800 rounded-xl p-6 space-y-4">
                {c.metrics.map(m => (
                  <div class="flex items-center gap-3">
                    <MoveRight size={16} class="text-brand-500 shrink-0" />
                    <span class="text-white font-medium">{m}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
