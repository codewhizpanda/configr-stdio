---
import { MoveRight } from 'lucide-astro';

const cases = [
  {
    tag: 'Sales Cloud',
    title: 'CRM consolidation for a regional real estate firm',
    problem: 'Agents were tracking leads in spreadsheets and email threads. No pipeline visibility, no forecasting, and deals falling through the cracks.',
    solution: 'Implemented Sales Cloud with custom lead routing flows, opportunity stages aligned to their sales process, and automated follow-up reminders.',
    result: 'Pipeline visibility went from zero to real-time. The sales manager now runs weekly reviews in Salesforce instead of chasing down spreadsheets.',
    metrics: ['100% pipeline visibility', 'Lead response time ↓ 60%', 'Team adopted in week 1'],
  },
  {
    tag: 'Service Cloud',
    title: 'Support transformation for a growing SaaS company',
    problem: 'Customer support ran through a shared email inbox. No SLAs, no routing, no reporting — and a frustrated team burning out on manual triage.',
    solution: 'Deployed Service Cloud with omni-channel case routing, escalation workflows, SLA tracking, and a knowledge base for common issues.',
    result: 'Ticket resolution time dropped significantly in the first month. The support team had the tooling to finally match their growth.',
    metrics: ['Resolution time ↓ 40%', 'CSAT scores improved', 'Zero dropped tickets'],
  },
  {
    tag: 'Loyalty Cloud',
    title: 'Loyalty programme launch for a retail brand',
    problem: 'The client ran a manual points programme in spreadsheets with no real-time member visibility, inconsistent reward redemptions, and zero analytics.',
    solution: 'Implemented Salesforce Loyalty Management with tiered membership, points accrual rules, promotional vouchers, and a member-facing Experience Cloud portal.',
    result: 'The programme went live on schedule. Members could track points in real time and the marketing team finally had engagement data to work with.',
    metrics: ['Launched on schedule', 'Real-time points tracking', 'Full analytics from day one'],
  },
  {
    tag: 'Field Service Lightning',
    title: 'Field workforce management for a facilities company',
    problem: 'Scheduling was done over phone calls and a whiteboard. Jobs were double-booked, engineers had no mobile access to work orders, and billing was delayed.',
    solution: 'Rolled out Field Service Lightning with the dispatcher console, work order management, mobile app for field engineers, and integration to their billing system.',
    result: 'Scheduling conflicts dropped to near zero. Field engineers had everything they needed on their phones — job details, parts, customer history.',
    metrics: ['Scheduling conflicts ↓ 90%', 'Mobile-first field team', 'Faster billing cycle'],
  },
  {
    tag: 'Experience Cloud',
    title: 'Partner portal for a wholesale distributor',
    problem: 'Partners were emailing the internal team for order updates, pricing, and support — consuming hours of staff time every day.',
    solution: 'Built an Experience Cloud partner portal with order tracking, custom pricing visibility, case submission, and role-based content access.',
    result: 'Partner self-service went from 0% to handling 70% of routine enquiries. The internal team reclaimed hours of time per day.',
    metrics: ['70% queries self-served', 'Partner satisfaction up', 'Internal team hours freed'],
  },
];
---

<section id="case-studies" class="section-padding border-t border-neutral-800/50">
  <div class="container-max">
    <div class="reveal mb-14">
      <p class="text-brand-500 font-semibold text-sm uppercase tracking-widest mb-3">Case Studies</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Problems solved</h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        Real projects, real outcomes. Details anonymized to protect client confidentiality.
      </p>
    </div>

    <div class="space-y-6">
      {cases.map((c) => (
        <div class="reveal bg-neutral-900 border border-neutral-800 rounded-2xl p-8 hover:border-neutral-700 transition-all duration-300">
          <div class="flex flex-col lg:flex-row lg:gap-12">
            <div class="lg:w-2/3">
              <span class="inline-block bg-brand-900/50 border border-brand-500/30 text-brand-400 text-xs font-semibold px-3 py-1 rounded-full mb-4">
                {c.tag}
              </span>
              <h3 class="text-2xl font-bold text-white mb-6">{c.title}</h3>

              <div class="space-y-4">
                <div>
                  <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-1">Problem</p>
                  <p class="text-slate-300">{c.problem}</p>
                </div>
                <div>
                  <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-1">What I did</p>
                  <p class="text-slate-300">{c.solution}</p>
                </div>
                <div>
                  <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-1">Result</p>
                  <p class="text-slate-300">{c.result}</p>
                </div>
              </div>
            </div>

            <div class="lg:w-1/3 mt-8 lg:mt-0 flex flex-col justify-center">
              <div class="bg-neutral-950 border border-neutral-800 rounded-xl p-6 space-y-4">
                {c.metrics.map(m => (
                  <div class="flex items-center gap-3">
                    <MoveRight size={16} class="text-brand-500 shrink-0" />
                    <span class="text-white font-medium">{m}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
