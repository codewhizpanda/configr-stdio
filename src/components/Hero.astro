---

<section id="hero" class="min-h-screen flex items-center section-padding pt-32">
  <div class="container-max w-full">
    <div class="max-w-3xl">
      <div class="reveal inline-flex items-center gap-2 bg-brand-900/40 border border-brand-500/30 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
        <span class="text-brand-400 text-sm font-medium">Available for new projects</span>
      </div>

      <h1 class="reveal text-5xl md:text-6xl lg:text-7xl font-extrabold text-white leading-[1.05] tracking-tight mb-6" style="transition-delay:100ms">
        Salesforce implementations
        <span class="text-brand-500"> that actually stick.</span>
      </h1>

      <p class="reveal text-slate-400 text-xl md:text-2xl leading-relaxed mb-10 max-w-2xl" style="transition-delay:200ms">
        CipherCloud Studio helps small and mid-sized businesses go live on Salesforce — and stay live.
        No drawn-out projects. No surprise complexity. Just clean builds your team
        will actually use.
      </p>

      <div class="reveal flex flex-col sm:flex-row gap-4" style="transition-delay:300ms">
        <a
          href="#contact"
          class="bg-brand-600 hover:bg-brand-700 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-all duration-200 hover:shadow-lg hover:shadow-brand-600/25 text-center"
        >
          Let's talk about your project
        </a>
        <a
          href="#case-studies"
          class="border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-white font-semibold px-8 py-4 rounded-xl text-lg transition-all duration-200 text-center"
        >
          See our work
        </a>
      </div>

      <div class="reveal mt-16 flex flex-wrap gap-8 items-center" style="transition-delay:400ms">
        <div class="text-center">
          <p class="text-3xl font-bold text-white">11+</p>
          <p class="text-slate-500 text-sm mt-1">Years of Experience</p>
        </div>
        <div class="w-px h-10 bg-neutral-800"></div>
        <div class="text-center">
          <p class="text-3xl font-bold text-white">6</p>
          <p class="text-slate-500 text-sm mt-1">Salesforce Clouds</p>
        </div>
        <div class="w-px h-10 bg-neutral-800"></div>
        <div class="text-center">
          <p class="text-3xl font-bold text-white">3</p>
          <p class="text-slate-500 text-sm mt-1">Certifications</p>
        </div>
        <div class="w-px h-10 bg-neutral-800"></div>
        <div class="text-center">
          <p class="text-3xl font-bold text-white">6</p>
          <p class="text-slate-500 text-sm mt-1">Industries</p>
        </div>
      </div>
    </div>
  </div>
</section>
