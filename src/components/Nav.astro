---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'About', href: '#about' },
  { label: 'Certifications', href: '#certifications' },
  { label: 'Case Studies', href: '#case-studies' },
  { label: 'Experience', href: '#experience' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-slate-950/80 backdrop-blur-md border-b border-slate-800/50">
  <div class="container-max flex items-center justify-between h-16 px-6 md:px-12 lg:px-24">
    <a href="#hero" class="text-white font-semibold text-lg tracking-tight">
      CipherCloud<span class="text-brand-500"> Studio</span>
    </a>
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-slate-400 hover:text-white text-sm font-medium transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    <a
      href="#contact"
      class="bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors duration-200"
    >
      Let's talk
    </a>
  </div>
</nav>
