---
const navLinks = [
  { label: 'Services', href: '/#services' },
  { label: 'Industries', href: '/#industries' },
  { label: 'About', href: '/#about' },
  { label: 'Certifications', href: '/#certifications' },
  { label: 'Case Studies', href: '/#case-studies' },
  { label: 'Collaborate', href: '/#join' },
  { label: 'Blog', href: '/blog' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-neutral-950/80 backdrop-blur-md border-b border-neutral-800/50">
  <div class="flex items-center justify-between h-16 px-6 md:px-12 lg:px-16 w-full">
    <a href="/" class="flex items-center gap-3 shrink-0">
      <span class="font-mono font-bold text-xs bg-neutral-900 border border-neutral-800 px-2 py-1 rounded-md hidden sm:inline-block">
        <span class="text-brand-500">&lt;cs</span><span class="text-white"> /&gt;</span>
      </span>
      <span class="font-mono font-semibold text-base tracking-tight whitespace-nowrap">
        <span class="text-brand-500">&lt;configr</span><span class="text-white"> stdio /&gt;</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-4 ml-auto mr-4">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-slate-400 hover:text-white text-xs font-medium transition-colors duration-200 whitespace-nowrap"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA (desktop) -->
    <a
      href="/#contact"
      class="hidden md:inline-block bg-brand-600 hover:bg-brand-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors duration-200 shrink-0"
    >
      Let's talk
    </a>

    <!-- Burger (mobile) -->
    <button
      id="nav-burger"
      aria-label="Open menu"
      aria-expanded="false"
      class="md:hidden flex flex-col justify-center items-center gap-1.5 w-8 h-8"
    >
      <span class="burger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
      <span class="burger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
      <span class="burger-line block w-6 h-0.5 bg-white transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden flex-col bg-neutral-950 border-t border-neutral-800/50 px-6 pb-6 pt-4 gap-1"
  >
    {navLinks.map(link => (
      <a
        href={link.href}
        class="nav-mobile-link block text-slate-300 hover:text-white font-medium py-3 border-b border-neutral-800/50 transition-colors duration-200"
      >
        {link.label}
      </a>
    ))}
    <a
      href="/#contact"
      class="nav-mobile-link mt-4 block text-center bg-brand-600 hover:bg-brand-700 text-white font-semibold px-4 py-3 rounded-lg transition-colors duration-200"
    >
      Let's talk
    </a>
  </div>
</nav>

<script>
  const burger = document.getElementById('nav-burger');
  const menu = document.getElementById('mobile-menu');
  const lines = burger?.querySelectorAll('.burger-line');

  burger?.addEventListener('click', () => {
    const isOpen = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!isOpen));

    if (isOpen) {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
      lines?.[0].classList.remove('rotate-45', 'translate-y-2');
      lines?.[1].classList.remove('opacity-0');
      lines?.[2].classList.remove('-rotate-45', '-translate-y-2');
    } else {
      menu?.classList.remove('hidden');
      menu?.classList.add('flex');
      lines?.[0].classList.add('rotate-45', 'translate-y-2');
      lines?.[1].classList.add('opacity-0');
      lines?.[2].classList.add('-rotate-45', '-translate-y-2');
    }
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      burger?.setAttribute('aria-expanded', 'false');
      lines?.[0].classList.remove('rotate-45', 'translate-y-2');
      lines?.[1].classList.remove('opacity-0');
      lines?.[2].classList.remove('-rotate-45', '-translate-y-2');
    });
  });
</script>
