---
const experience = [
  {
    type: 'work',
    title: 'Senior Salesforce Developer',
    org: 'Arbour Group',
    period: '2025 – Present',
    bullets: [
      'Leading the D365–Salesforce integration project',
      'Built Lightning Web Components to enhance user experience in Service Cloud',
    ],
  },
  {
    type: 'work',
    title: 'Senior Developer',
    org: 'N-able Philippines',
    period: '2021 – 2025',
    bullets: [
      'Led legacy system decommissioning and improved Community portal features, resolving key production issues',
      'Built integrations for seamless external data exchange',
      'Maintained project progress via JIRA and created thorough feature documentation in Confluence',
    ],
  },
  {
    type: 'work',
    title: 'Senior Full-Stack Software Engineer',
    org: 'Manulife IT Delivery Center',
    period: '2019 – 2021',
    bullets: [
      'Conducted code reviews and security scans (Fortify, WebInspect) to ensure quality and compliance',
      'Collaborated with MicroServices team and Solution Architects on integrations and defect resolution',
      'Provided production support and participated actively in all Scrum ceremonies',
    ],
  },
  {
    type: 'work',
    title: 'Salesforce Developer',
    org: 'AXA Philippines',
    period: '2017 – 2019',
    bullets: [
      'Developed PDF generation and display systems by integrating external APIs via Salesforce HTTP callouts',
      'Designed custom access control and routing logic based on user profiles and field criteria',
      'Contributed to solution design through client consultations and technical input',
    ],
  },
  {
    type: 'work',
    title: 'Technical Consultant',
    org: 'Third Pillar Business Applications Inc.',
    period: '2015 – 2017',
    bullets: [
      'Led requirements gathering, solution design, and Salesforce configuration to align with business processes',
      'Delivered user training and provided ongoing post-production support',
    ],
  },
];

const education = [
  {
    type: 'cert',
    title: 'Salesforce Certified Platform Developer I',
    org: 'Salesforce · August 2020',
    period: '2020',
  },
  {
    type: 'cert',
    title: 'Salesforce Certified Platform App Builder',
    org: 'Salesforce · April 2018',
    period: '2018',
  },
  {
    type: 'cert',
    title: 'Salesforce Certified Administrator',
    org: 'Salesforce · April 2017',
    period: '2017',
  },
  {
    type: 'edu',
    title: 'Bachelor of Science in Information Technology',
    org: 'Polytechnic University of the Philippines – Taguig',
    period: '2011 – 2015',
  },
];

const all = [...experience, ...education];
---

<section id="experience" class="section-padding border-t border-neutral-800/50">
  <div class="container-max">
    <div class="reveal mb-14">
      <p class="text-brand-500 font-semibold text-sm uppercase tracking-widest mb-3">Background</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Experience & Education</h2>
    </div>

    <div class="reveal grid grid-cols-1 lg:grid-cols-2 gap-12" style="transition-delay:150ms">
      <div>
        <h3 class="text-slate-400 text-sm uppercase tracking-widest font-semibold mb-6">Work</h3>
        <div class="relative border-l border-neutral-800 pl-8 space-y-10">
          {experience.map(item => (
            <div class="relative">
              <div class="absolute -left-[2.35rem] top-1 w-4 h-4 bg-brand-600 rounded-full border-2 border-neutral-950"></div>
              <p class="text-slate-500 text-xs font-medium mb-1">{item.period}</p>
              <h4 class="text-white font-bold text-lg">{item.title}</h4>
              <p class="text-brand-400 text-sm font-medium mb-3">{item.org}</p>
              <ul class="space-y-1.5">
                {item.bullets && item.bullets.map(b => (
                  <li class="text-slate-400 text-sm flex gap-2">
                    <span class="text-slate-600 mt-0.5">•</span>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-slate-400 text-sm uppercase tracking-widest font-semibold mb-6">Certifications & Education</h3>
        <div class="relative border-l border-neutral-800 pl-8 space-y-8">
          {education.map(item => (
            <div class="relative">
              <div class={`absolute -left-[2.35rem] top-1 w-4 h-4 rounded-full border-2 border-neutral-950 ${item.type === 'cert' ? 'bg-emerald-500' : 'bg-slate-600'}`}></div>
              <p class="text-slate-500 text-xs font-medium mb-1">{item.period}</p>
              <h4 class="text-white font-bold">{item.title}</h4>
              <p class="text-slate-400 text-sm">{item.org}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
