---
import { Users, Headphones, Gift, Wrench, Globe, Plug, Check } from 'lucide-astro';

const services = [
  {
    icon: Users,
    title: 'Sales Cloud',
    description: 'End-to-end Sales Cloud implementations — lead management, opportunity tracking, forecasting, and automation built around how your sales team actually works.',
    outcomes: ['Custom sales process & stages', 'Pipeline visibility from day one', 'Automated follow-ups & alerts'],
  },
  {
    icon: Headphones,
    title: 'Service Cloud',
    description: 'Case management, routing, escalation rules, and knowledge bases that turn your support team into a well-oiled machine.',
    outcomes: ['Omni-channel case routing', 'SLA tracking & escalations', 'Self-service knowledge base'],
  },
  {
    icon: Gift,
    title: 'Loyalty Cloud',
    description: 'Salesforce Loyalty Management implementations — points, tiers, promotions, and member journeys that keep customers coming back.',
    outcomes: ['Points & tier configuration', 'Promotion & voucher setup', 'Member portal integration'],
  },
  {
    icon: Wrench,
    title: 'Field Service Lightning',
    description: 'Mobile workforce management — scheduling, dispatching, work orders, and asset tracking for teams that work in the field.',
    outcomes: ['Work order & job management', 'Dispatcher console setup', 'Mobile offline capabilities'],
  },
  {
    icon: Globe,
    title: 'Experience Cloud',
    description: 'Customer and partner portals, self-service sites, and community hubs — built on Experience Cloud and connected to your Salesforce data.',
    outcomes: ['Customer & partner portals', 'Self-service case deflection', 'Branded site configuration'],
  },
  {
    icon: Plug,
    title: 'Integrations',
    description: 'Connecting Salesforce to the rest of your tech stack — ERPs, marketing platforms, payment systems, and custom APIs via REST, SOAP, or middleware.',
    outcomes: ['REST & SOAP API integrations', 'Middleware & ETL setup', 'Real-time & batch sync'],
  },
];
---

<section id="services" class="section-padding border-t border-neutral-800/50">
  <div class="container-max">
    <div class="reveal mb-14">
      <p class="text-brand-500 font-semibold text-sm uppercase tracking-widest mb-3">Services</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">What we can do for you</h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        Every engagement is outcome-focused. We define what success looks like before writing a single line of config.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="reveal bg-neutral-900 border border-neutral-800 rounded-2xl p-7 hover:border-brand-500/40 transition-all duration-300 group">
          <div class="w-10 h-10 bg-brand-900/50 border border-brand-500/20 rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-900 group-hover:border-brand-500/40 transition-all">
            <service.icon size={20} class="text-brand-400" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-brand-400 transition-colors">{service.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-5">{service.description}</p>
          <ul class="space-y-2">
            {service.outcomes.map(outcome => (
              <li class="flex items-center gap-2 text-sm text-slate-300">
                <Check size={14} class="text-brand-500 shrink-0" />
                {outcome}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
