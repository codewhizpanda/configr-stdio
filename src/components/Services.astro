---
import { Zap, Wrench, Shield, BookOpen, ArrowLeftRight, Check } from 'lucide-astro';

const services = [
  {
    icon: Zap,
    title: 'Implementation',
    description: 'Full Salesforce org setup from scratch — configured to your actual business process, not a generic template.',
    outcomes: ['Go-live in weeks, not months', 'Clean data model from day one', 'Team trained and confident'],
  },
  {
    icon: Wrench,
    title: 'Customization',
    description: 'Flows, custom objects, validation rules, and Apex — built so your Salesforce works exactly the way your team does.',
    outcomes: ['Automate repetitive tasks', 'Eliminate manual data entry', 'Tailored to your workflow'],
  },
  {
    icon: Shield,
    title: 'Admin Support',
    description: 'Ongoing Salesforce administration without the cost of a full-time hire. I keep your org healthy and your team unblocked.',
    outcomes: ['User management & permissions', 'Reports and dashboards', 'Troubleshooting & fixes'],
  },
  {
    icon: BookOpen,
    title: 'Training',
    description: 'Hands-on training sessions that actually land. Your team learns by doing — in your own org, with your own data.',
    outcomes: ['Role-based training paths', 'Custom documentation', 'Higher adoption rates'],
  },
  {
    icon: ArrowLeftRight,
    title: 'Migrations',
    description: 'Moving from another CRM or a messy legacy org? I handle the data mapping, deduplication, and cutover — safely.',
    outcomes: ['Data integrity guaranteed', 'Zero downtime cutover', 'Historical data preserved'],
  },
];
---

<section id="services" class="section-padding border-t border-neutral-800/50">
  <div class="container-max">
    <div class="mb-14">
      <p class="text-brand-500 font-semibold text-sm uppercase tracking-widest mb-3">Services</p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">What I can do for you</h2>
      <p class="text-slate-400 text-lg max-w-2xl">
        Every engagement is outcome-focused. We define what success looks like before we write a single line of config.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="bg-neutral-900 border border-neutral-800 rounded-2xl p-7 hover:border-brand-500/40 transition-all duration-300 group">
          <div class="w-10 h-10 bg-brand-900/50 border border-brand-500/20 rounded-xl flex items-center justify-center mb-5 group-hover:bg-brand-900 group-hover:border-brand-500/40 transition-all">
            <service.icon size={20} class="text-brand-400" />
          </div>
          <h3 class="text-xl font-bold text-white mb-3 group-hover:text-brand-400 transition-colors">{service.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-5">{service.description}</p>
          <ul class="space-y-2">
            {service.outcomes.map(outcome => (
              <li class="flex items-center gap-2 text-sm text-slate-300">
                <Check size={14} class="text-brand-500 shrink-0" />
                {outcome}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
